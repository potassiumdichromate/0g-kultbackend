# Copy to .env at the repo root for docker-compose, and/or into each service's own .env for local `npm run dev`.

# --- Postgres ---
POSTGRES_USER=platform
POSTGRES_PASSWORD=platform
POSTGRES_DB=kultbrowser
# Host port 5434, not the default 5432, because this machine already runs a native
# Windows PostgreSQL service on 5432 — see the comment at the top of docker-compose.yml.
DATABASE_URL=postgresql://platform:platform@localhost:5434/kultbrowser?schema=public

# --- Redis --- (host port 6380, not the default 6379, to avoid clashing with any other
# local stack already using 6379 — see the comment at the top of docker-compose.yml)
REDIS_URL=redis://localhost:6380

# --- NATS --- (host ports 4322/8322, not the defaults, for the same reason)
NATS_URL=nats://localhost:4322

# --- Identity (must match each game's existing BROWSER_JWT_SECRET to be a drop-in issuer) ---
PLATFORM_JWT_SECRET=change-me-to-a-real-32-byte-secret
PLATFORM_JWT_EXPIRES_IN=7d

# --- Existing game backends (read-only, public endpoints only — never write to these) ---
ZERODASH_BACKEND_URL=https://zerog-zerodash.onrender.com
# NOTE: this URL is a guess and returned 404 when checked live during development — get the
# real deployed Warzone backend URL before relying on warzone-adapter for anything but a code read.
WARZONE_BACKEND_URL=https://warzone-backend-0g.onrender.com

# --- Adapter polling cadence (ms) ---
ADAPTER_POLL_INTERVAL_MS=15000

# --- 0G Storage / Compute (Round 2, managed save pipeline) ---
# Leave ZG_PRIVATE_KEY/ZG_RPC_URL unset to use the local-disk storage driver (dev/verification
# only — see shared/zg-client/src/storage.ts). Set both to use real 0G Storage in production.
ZG_PRIVATE_KEY=
ZG_RPC_URL=
ZG_INDEXER_RPC=
# Leave unset to use the local-disk fallback dir (tmpdir()/0g-kultbrowser-local-storage).
ZG_LOCAL_STORAGE_DIR=
# Leave unset and verification-service gracefully skips anti-cheat (computeStatus: "skipped"),
# identical to both existing repos' documented behavior with no compute key configured.
ZG_COMPUTE_API_KEY=

# --- Service ports ---
API_GATEWAY_PORT=3000
IDENTITY_SERVICE_PORT=3001
PROFILE_SERVICE_PORT=3002
LEADERBOARD_SERVICE_PORT=3003
ACHIEVEMENT_SERVICE_PORT=3004
REWARD_SERVICE_PORT=3005
ANALYTICS_SERVICE_PORT=3006
NOTIFICATION_SERVICE_PORT=3007
SAVE_SERVICE_PORT=3008
VERIFICATION_SERVICE_PORT=3009
